{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/refs/heads/main/nicegui/static/tauri.schema.json",
  "productName": "Gemini",
  "version": "1.1.0",
  "identifier": "com.nwn900.gemini",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "https://gemini.google.com/app"
  },
  "app": {
    "windows": [],
    "security": {
      "dangerousDisableAssetCspModification": true,
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    }
  }
}
